# 环境变量配置文件示例
# 复制此文件为 .env 并填入你的实际配置



LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo

# 项目路径
PROJECT_ROOT=

# 筛选条件默认值
DEFAULT_CITIES=北京，上海，深圳，杭州
MIN_SALARY=5000
MAX_SALARY=30000
JOB_TYPES=实习，全职

# 爬虫配置
REQUEST_DELAY=1.0
MAX_RETRIES=3

# 投递配置
AUTO_SUBMIT=false
DAILY_LIMIT=50

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
